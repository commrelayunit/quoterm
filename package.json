{
  "name": "quoterm",
  "version": "0.1.1",
  "description": "Quoted terminal-style inline feedback for React — a focused alternative to toast popups.",
  "license": "MIT",
  "author": "commrelayunit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/commrelayunit/quoterm.git"
  },
  "homepage": "https://github.com/commrelayunit/quoterm#readme",
  "bugs": {
    "url": "https://github.com/commrelayunit/quoterm/issues"
  },
  "keywords": [
    "react",
    "component",
    "feedback",
    "toast",
    "inline-feedback",
    "terminal",
    "notification",
    "typescript",
    "accessibility"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css",
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react,react-dom && cp src/styles.css dist/style.css && cp src/styles.css dist/styles.css",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.2.0 <20",
    "react-dom": ">=18.2.0 <20"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.4"
  }
}
